{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "platform/**/*.tsx",
    "benchmark/**/*.ts",
    "fixtures/**/*.ts",
    "src/scripts/**/*.ts"
  ]
}
